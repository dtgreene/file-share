<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>File Server</title>
  </head>
  <body class="flex justify-center p-12">
    <div class="flex flex-col gap-4 max-w-3xl w-full">
      <div>
        <div>Viewing</div>
        <div class="text-zinc-600">{{ sharePath }}</div>
      </div>

      <div class="border border-zinc-300 rounded">
        {{#if currentFiles}}
        <table class="table-fixed w-full">
          <thead>
            <tr class="border-b border-zinc-300">
              <th class="p-2 text-left">Name</th>
              <th class="p-2 text-center w-40">Last Modified</th>
              <th class="p-2 text-right w-20">Size</th>
            </tr>
          </thead>
          <tbody>
            {{#each currentFiles}}
            <tr class="border-b border-zinc-300 last:border-none">
              <td class="p-2 overflow-hidden text-left">
                <a
                  class="inline-flex items-center gap-2 cursor-pointer hover:underline"
                  href="/download/{{ path }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" class="shrink-0" viewBox="0 0 16 16">
                    <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                    <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
                  </svg>
                  {{ path }}
                </a>
              </td>
              <td class="p-2 overflow-hidden text-center">{{ modified }}</td>
              <td class="p-2 overflow-hidden text-right">{{ size }}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{else}}
        <div class="p-2">No files found</div>
        {{/if}}
      </div>
    </div>
    <script>
      const socket = new WebSocket('/ws');

      socket.addEventListener('message', (event) => {
        if (event.data === 'files_changed') {
          window.location.reload();
        }
      });
    </script>
  </body>
</html>
